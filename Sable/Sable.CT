//============================================================================//

newmem:

newmem_qt_custom_marcador_mapa:
  push rax
  lea rax, [rcx+18]
  mov [qt_custom_marcador_mapa], rax
  pop rax
  sub eax,[rcx+18]
  lea rcx,[rsp+30]
  jmp return_qt_custom_marcador_mapa

align 16
newmem_dinheiro_sub:
  push rax
  lea rax,[rdi+28]
  mov [dinheiro], rax
  pop rax
  sub [rdi+28],esi
  mov rsi,[rsp+48]
  jmp return_dinheiro_sub

align 16
newmem_dinheiro_add:
  push rax
  lea rax, [rdi+28]
  mov [dinheiro], rax
  pop rax

  add [rdi+28],esi
  mov rsi,[rsp+48]
  jmp return_dinheiro_add

align 16
newmem_posicao_peixe_minigame_pesca:
  push rax
  lea rax,[rcx+0000021C]
  mov [posicao_peixe_minigame_pesca],rax
  pop rax
  movss xmm1,[rcx+0000021C]
  jmp return_posicao_peixe_minigame_pesca

align 16
newmem_sprintstaminarate:
  push rax
  lea rax,[rcx+000000D8]
  mov [sprintstaminarate],rax
  pop rax
  mulss xmm7,[rcx+000000D8]
  jmp return_sprintstaminarate

align 16
newmem_minigame_pesca_finalizado:
  push rax
  lea rax, [rax+0000020D]
  mov [minigame_pesca_finalizado], rax
  pop rax
  movzx r8d,byte ptr [rax+0000020D]
  jmp return_minigame_pesca_finalizado

align 16
newmem_estado_minigame_pesca:
  push rax
  lea rax, [rax+0000020C]
  mov [estado_minigame_pesca], rax
  pop rax
  movzx r8d,byte ptr [rax+0000020C]
  jmp return_estado_minigame_pesca

align 16
newmem_estado_pesca:
  push rax
  lea rax, [rcx+000001F8]
  mov [estado_pesca], rax
  pop rax
  cmp dword ptr [rcx+000001F8],02
  jmp return_estado_pesca

align 16
newmem_forca_do_lancamento_da_isca:
  push rax
  lea rax, [rcx+000001FC]
  mov [forca_do_lancamento_da_isca], rax
  pop rax
