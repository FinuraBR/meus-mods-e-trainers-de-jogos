label(code)
label(return)
label(newmem_climbing_stamina)
label(return_climbing_stamina)

newmem:

code:
  nop
  nop
  nop
  nop
  nop
  jmp return

newmem_climbing_stamina:
  nop
  nop
  nop
  xor r8d,r8d
  jmp return_climbing_stamina

INJECT:
  jmp newmem
return:

INJECT_CLIMBING_STAMINA:
  jmp newmem_climbing_stamina
  nop
return_climbing_stamina:

