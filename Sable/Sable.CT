  pop rax
  movss xmm0,[r14+00000204]
  jmp return_progresso_minigame_pesca

align 16
newmem_fps_counter:
  push rax
  lea rax,[rax+28]
  mov [fps_counter],rax
  pop rax
  cmp [rax+28],r14b
  je GameAssembly.dll+6DB058
  jmp return_fps_counter

align 16
newmem_fmod_global_parameter_debug:
  push rax
  lea rax,[rax+38]
  mov [fmod_global_parameter_debug],rax
  pop rax
  cmp [rax+38],r14b
  je GameAssembly.dll+6DB28C
  jmp return_fmod_global_parameter_debug

align 16
newmem_stamina_recharge_rate:
  push rax
  lea rax,[rsi+00000114]
  mov [stamina_recharge_rate],rax
  pop rax
  movss xmm8,[rsi+00000114]
  jmp return_stamina_recharge_rate

align 16
newmem_climbing_stamina:
  push rax
  lea rax,[rax+28]
  mov [climbing_stamina],rax
  pop rax
  divss xmm0,[rax+28]
  jmp return_climbing_stamina

align 16
newmem_air_move_force:
  push rax
  lea rax,[rdi+00000168]
  mov [air_move_force],rax
  pop rax
  movss xmm3,[rdi+00000168]
  jmp return_air_move_force

